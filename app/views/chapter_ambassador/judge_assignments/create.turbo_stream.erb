<%= turbo_stream.remove(@judge) %>
<%= turbo_stream.remove("no-judges-found") %>

<%= turbo_stream.append "judges-assigned-to-team",
  partial: "admin/regional_pitch_events/judges/judge_assigned_to_team",
  locals: {judge: @judge, team: @team }
%>

<%= turbo_stream.append "flash-messages" do %>
  <%= render "flash_messages" %>
<% end %>

<%= turbo_stream.replace dom_id(@team, :judge_count) do %>
  <%= render "admin/regional_pitch_events/team_judge_count", team: @team %>
<% end %>

<%= turbo_stream.replace dom_id(@judge, :teams_count) do %>
  <%= render "admin/regional_pitch_events/judge_teams_count", judge: @judge, event: @team.event %>
<% end %>
