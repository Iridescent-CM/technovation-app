<div class="mb-4">
  <% if current_judge.live_event? %>
    <%= render "judge/dashboards/onboarded/rebrand/live_events" %>
  <% else %>
    <p>
      Welcome to the online judging portal! Judging is currently closed but will open soon.
    </p>
    
    <%= render "judge/dashboards/onboarded/rebrand/social_media_templates" %>
    
    <p class="mt-4">
      You will receive an email when judging opens. Please check back on the dates listed below!
    </p>
    <%= render "judge/dashboards/rebrand/important_dates" %>
  <% end %>
</div>