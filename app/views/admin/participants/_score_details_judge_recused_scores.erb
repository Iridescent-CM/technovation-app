<% if recused_scores.any? %>
  <table class="width--100-percent">
    <thead>
      <tr>
        <th>Judge</th>
        <th>Reason</th>
        <th>Round</th>
      </tr>
    </thead>

    <tbody>
    <% recused_scores.each do |score| %>
      <tr>
        <td>
          <%= link_to score.judge_name,
            send("#{current_scope}_participant_path", id: score.judge_profile.account_id) %>
        </td>
        
        <td>
          <%= render "admin/participants/judge_recusal_reason", score: score %>
        </td>

        <td><%= score.round.humanize %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% else %>
  <p>
    No recused scores
  </p>
<% end %>
