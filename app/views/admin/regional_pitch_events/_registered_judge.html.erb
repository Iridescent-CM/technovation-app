<tr id="<%= dom_id(judge, :registered) %>">
  <td>
    <% if judge.pending_registration? %>
      <%= judge.name.presence || "Invited Judge" %>
    <% else %>
      <%= link_to judge.name,
      send("#{current_scope}_participant_path", judge.account.id),
      data: { turbo: false } %>
    <% end %>
  </td>

  <td>
    <%= judge.email %>
  </td>

  <td>
    <span id="<%= dom_id(judge, :teams_count) %>">
      <%= judge.assigned_teams_for_event(event).count %>
    </span>
  </td>

  <td>
    <span class="pill pill-<%= judge.status == "ready" ? "green" : "orange" %>" style="white-space: nowrap;">
      <%= judge.human_status %>
    </span>
  </td>

  <% if current_account.chapter_ambassador? %>
    <td>
      <%= button_to "Remove",
        chapter_ambassador_event_event_judge_path(event, judge),
        method: :delete,
        params: { scope: judge.class.name },
        class: "button button--danger" %>
    </td>
  <% end %>
</tr>
